# Ship MCP endpoint. Token may be embedded as ?mcp_token=... query param.
SHIP_MCP_URL=https://ship.deodap.in/mcp?mcp_token=YOUR_TOKEN
# Optional: bearer token sent as Authorization header instead of query param.
SHIP_MCP_TOKEN=

# --- Sync tuning (all optional; sensible defaults in lib/config.ts) ---
# Rolling data window in days — every order with an order_date inside it is
# cached, everything older is pruned each sync. Default 180 (6 months, ~957k
# orders, ~1.2GB of SQLite). The sync is incremental, so widening this does not
# slow the steady state; it just re-opens the backfill for the new days.
WINDOW_DAYS=180
# How much of each sync may go to backfilling history (day by day, newest first).
# Spent only until the window is full, then it's a no-op. ~10 days per cycle at
# 60s; a cold 180-day backfill takes ~18 cycles. Default 60000.
BACKFILL_BUDGET_MS=60000
# Days of overlap the incremental pull re-fetches. The portal's date filters are
# day-granular and updated_at isn't returned, so there's no timestamp watermark —
# the overlap is what stops an order changing after the cut-off from being missed.
# Upserts are idempotent, so this only costs bandwidth. Default 2.
INCREMENTAL_OVERLAP_DAYS=2
# Bound for the best-effort KPI-aggregate calls (they keep the previous cached
# value on failure). Short so a flaky portal can't blow the budget. Default 15000.
KPI_TIMEOUT_MS=15000
# Max concurrent MCP calls. Lower = gentler on the portal (rate-limit safe).
# Default 6.
MCP_CONCURRENCY=6
# Wall-clock backstop for one sync. Default 120000.
SYNC_TIME_BUDGET_MS=120000
# Server-side background sync is the SOLE sync driver (the dashboard no longer
# triggers syncs). Gap between runs, measured from completion. Default 300000 (5m).
BACKGROUND_SYNC=true
BACKGROUND_SYNC_GAP_MS=300000

# Courier credentials source. Every courier tracking client below reads its
# credentials from these env vars FIRST, then falls back to this CSV — so
# dropping shipping_courier_credentials.csv in the project root is enough to
# light up live tracking for all accounts without filling in every var here.
# Override the path only if the CSV lives elsewhere.
COURIER_CREDENTIALS_CSV=

# --- Live courier tracking on Sync ---
# During each background sync, after pulling panel data, fetch live status
# directly from the courier sites for every synced order (AWB + supported
# courier) and store it next to the panel status. This makes sync much slower
# (one call per order), so it only runs with whatever time budget is left.
LIVE_TRACK_ON_SYNC=true
# Max orders to live-track per sync. 0 = no cap (track every eligible order).
LIVE_TRACK_MAX=0
# Concurrent courier calls during the live-track phase. Higher = faster sync but
# more load on courier APIs (raise cautiously to avoid rate-limits/blocks).
LIVE_TRACK_CONCURRENCY=6
# Minimum gap (ms) between courier call STARTS across all workers. Guards against
# an IP block: unthrottled, concurrency 6 bursts ~25 req/s at one courier, which
# is enough for DTDC to connection-reset (ECONNRESET). ~75ms caps it near 13/s.
LIVE_TRACK_SPACING_MS=75
# Minimum gap (ms) between call starts AT ONE COURIER, on top of the global gate.
# The global gate caps total outbound rate but not its distribution: the sweep is
# priority-ordered, so the batch concentrates on TAT breaches, which skew to the
# highest-volume courier (DTDC). That aims nearly the whole global rate at one
# host and trips its throttle. ~200ms caps any single courier near 5/s. Default 200.
LIVE_TRACK_COURIER_SPACING_MS=200
# Orders live-tracked per sync (least-recently-checked first; results carry over
# between syncs so coverage accumulates).
LIVE_TRACK_MAX=800
# Dedicated budget (ms) for the live-track phase, separate from the fetch budget.
# Throughput is set by LIVE_TRACK_SPACING_MS, not concurrency: the rate gate
# serializes call starts, so this phase reaches ~BUDGET/SPACING orders per sync
# (60s / 75ms ~= 800). Keep it in step with LIVE_TRACK_MAX — at 30s only half of
# each 800-order batch is ever called.
LIVE_TRACK_BUDGET_MS=60000
# Per-request ceiling (ms) for one courier tracking call. Correctness guard, not
# tuning: without it a courier that accepts the socket then goes silent pins a
# worker (Node's http.request has no default timeout; undici's is 300s), and the
# phase deadline is only checked between orders — so one bad socket would stall
# the sync, and the scheduler behind it, for the life of the process.
COURIER_HTTP_TIMEOUT_MS=15000

# Shiprocket REST tracking endpoint. Override only if you need a custom base URL.
SHIPROCKET_API_BASE_URL=https://apiv2.shiprocket.in/v1/external
# Shiprocket API bearer token for AWB tracking.
SHIPROCKET_API_TOKEN=

# Delhivery tracking endpoint. Override only if you need a custom base URL.
DELHIVERY_API_BASE_URL=https://track.delhivery.com/api/v1/packages/json
# Delhivery API token for waybill tracking.
DELHIVERY_API_TOKEN=

# Shree Anjani Courier tracking endpoint. Override only for a custom base URL.
# Called as GET {base}/{barcode_number} with api-key / api-secret headers.
ANJANI_API_BASE_URL=https://api-customer.shreeanjani.co.in/tpapi/tracking
# Shree Anjani API credentials for docket/barcode tracking.
ANJANI_API_KEY=
ANJANI_API_SECRET=

# Trackon Couriers Customer Shipment Tracking API (latest host per the API doc;
# old host was http://trackoncourier.com:5455). Override only for a custom URL.
# Called as GET {base}?AWBNo={awb}&AppKey=...&userID=...&Password=...
TRACKON_API_BASE_URL=https://api.trackon.in/CrmApi/t1/AWBTrackingCustomer
# Trackon API credentials — provided by the Trackon Sales/CRM coordinator. REQUIRED
# to fetch Trackon status (the #1 courier by volume); without them calls 401.
TRACKON_APP_KEY=
TRACKON_USER_ID=
TRACKON_PASSWORD=

# DTDC live tracking. POST {base} with X-Access-Token header and body
# { trkType: "cnno", strcnno: "{awb}", addtnlDtl: "Y" }.
# NOTE: blktracksvc.dtdc.com serves an incomplete TLS chain, so lib/dtdc.ts posts
# through a relaxed-TLS agent scoped to this client only.
DTDC_API_BASE_URL=https://blktracksvc.dtdc.com/dtdc-api/rest/JSONCnTrk/getTrackDetails
# The REAL DTDC tracking tokens, shaped "{customerId}_trk_json:{hash}" — one per
# DTDC account, comma-separated. Tried in order until the docket resolves. Ask
# DTDC for these; the booking `api_key` will NOT work here (401).
DTDC_TRACKING_TOKENS=GL0000_trk_json:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy single-token override (superseded by DTDC_TRACKING_TOKENS).
DTDC_TRACKING_API_KEY=
# DTDC booking/soft-data account credentials. Not used by the tracking-only
# integration yet — kept here for a future booking/label integration.
DTDC_USERNAME=
DTDC_PASSWORD=
DTDC_TOKEN=
DTDC_API_KEY=
DTDC_CUSTOMER_ID=
DTDC_SERVICE_TYPE_ID=
